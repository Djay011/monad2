# Server
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Monad chain
RPC_URL=https://rpc.monad.xyz
CHAIN_ID=143

# Indexer target — only txs sent to this address are inspected for inscriptions
RECEIVER_WALLET=0x6fC09727F83Ef23782cF80Cd11e1bda534532267

# Indexer behavior
# Start block on first run (0 = current_tip - INITIAL_LOOKBACK)
START_BLOCK=0
INITIAL_LOOKBACK=2000
# Public Monad RPC has ~25 req/sec rate limit. Keep batches small.
POLL_INTERVAL_MS=4000
BATCH_SIZE=8
MAX_BLOCKS_PER_PASS=80
# Delay between batches inside a pass (ms) to stay under the rate limit
BATCH_DELAY_MS=400

# Database file (sqlite)
DB_PATH=./data/inscriptions.db
